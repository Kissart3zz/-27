      ],
      "source": [
        "n = int(input())\n",
        "\n",
        "x = list(map(int, input().split()))\n",
        "r = list(map(int, input().split()))\n",
        "\n",
        "dp = [0] * n\n",
        "\n",
        "for i in range(n):\n",
        "\n",
        "    dp[i] = r[i]\n",
        "\n",
        "    for j in range(i):\n",
        "\n",
        "        if x[i] - x[j] > 5:\n",
        "            dp[i] = max(dp[i], dp[j] + r[i])\n",
        "\n",
        "ans = max(dp)\n",
        "\n",
        "print(ans)"
      ]
    }
  ]
}