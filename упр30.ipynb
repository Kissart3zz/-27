      "source": [
        "n = int(input())\n",
        "\n",
        "w = list(map(int, input().split()))\n",
        "\n",
        "dp = [0] * n\n",
        "\n",
        "dp[0] = w[0]\n",
        "\n",
        "if n > 1:\n",
        "    dp[1] = max(w[0], w[1])\n",
        "\n",
        "for i in range(2, n):\n",
        "    dp[i] = max(dp[i - 1], dp[i - 2] + w[i])\n",
        "\n",
        "print(dp[n - 1])"
      ]
    }
  ]
}